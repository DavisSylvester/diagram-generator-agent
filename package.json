{
  "name": "diagram-generator-agent",
  "version": "0.1.0",
  "description": "Multi-agent pipeline that generates architecture diagrams from PRDs",
  "type": "module",
  "bin": {
    "diagram-generator-agent": "src/index.mts"
  },
  "scripts": {
    "start": "bun run src/index.mts",
    "dev": "bun --watch src/index.mts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint src/",
    "lint:fix": "bunx eslint src/ --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf .workspace out dist"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.7",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.4",
    "langchain": "^1.3.0",
    "langsmith": "^0.5.16",
    "ollama": "^0.6.3",
    "picocolors": "^1.1.1",
    "ulid": "^3.0.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^10.2.0",
    "@eslint/js": "^10.0.0",
    "typescript-eslint": "^8.32.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavisSylvester/diagram-generator-agent.git"
  },
  "keywords": [
    "diagram",
    "generator",
    "agent",
    "prd",
    "architecture",
    "mermaid",
    "plantuml",
    "llm",
    "langchain",
    "cli"
  ]
}
